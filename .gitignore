# ============================================================
#  ROOT .gitignore — Aaradhana Monorepo
#  Covers: root, client/, server/, Admin/client/
# ============================================================


# ── Secrets & environment variables (NEVER commit) ──────────
.env
.env.*
!**/.env.example          # .env.example files are safe to commit
*.pem
*.key
*.p12
*.jks
*.keystore
secrets/


# ── Node / JavaScript ────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ── Frontend build output (Vite / React) ─────────────────────
dist/
dist-ssr/
build/
.vite/
vite.config.js.timestamp-*
storybook-static/


# ── Java / Maven / Spring Boot ───────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.nar
*.ear
HELP.md

# Spring profile files that may contain raw secrets
application-local.properties
application-dev.properties
application-prod.properties
application-secrets.properties


# ── Testing & coverage ───────────────────────────────────────
coverage/
*.lcov
.nyc_output/


# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo


# ── ESLint cache ─────────────────────────────────────────────
.eslintcache


# ── IDE & editor configs ─────────────────────────────────────
# IntelliJ IDEA / WebStorm
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# VS Code  (keep the recommended-extensions list)
.vscode/
!.vscode/extensions.json

# Eclipse
.classpath
.project
.settings/
.factorypath
bin/

# NetBeans
/nbproject/
/nbdist/
/.nb-gradle/


# ── OS generated files ───────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# ── Docker ───────────────────────────────────────────────────
# Keep Dockerfile; ignore local/override compose files
docker-compose.override.yml
docker-compose.local.yml
.dockerenv


# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
spring.log


# ── Misc ─────────────────────────────────────────────────────
*.tmp
*.temp
*.swp
*.swo
*.bak
.cache/
