
# MongoDB
MONGODB_URI=

# JWT — use a random 64+ character string in production
JWT_SECRET=replace-with-a-long-random-secret-at-least-64-characters-long

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SendGrid email
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Aaradhana

# Gmail fallback SMTP (optional)
GMAIL_USERNAME=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Admin
ADMIN_EMAIL=admin@yourdomain.com
APP_URL=https://your-frontend.vercel.app

# Razorpay — use rzp_test_ keys for testing, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-from-razorpay-dashboard
